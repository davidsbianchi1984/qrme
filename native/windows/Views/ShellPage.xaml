<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QrmeStudio.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource QrmeScrBotBrush}">

    <NavigationView x:Name="Nav" IsBackButtonVisible="Collapsed" IsSettingsVisible="False"
                    PaneDisplayMode="Left" SelectionChanged="OnSelectionChanged"
                    Background="{StaticResource QrmeScrBotBrush}">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Overview" Tag="overview" IsSelected="True">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Home" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Chat" Tag="chat">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Message" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Community" Tag="community">
                <NavigationViewItem.Icon><SymbolIcon Symbol="People" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Compose" Tag="compose">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Edit" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Posts" Tag="posts">
                <NavigationViewItem.Icon><SymbolIcon Symbol="List" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Study" Tag="study">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Library" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Connect" Tag="connect">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Link" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Gaming" Tag="gaming">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Emoji" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Robots" Tag="robots">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Contact" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Reach" Tag="reach">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Map" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Settings" Tag="settings">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Setting" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <NavigationView.PaneFooter>
            <Button Content="Sign out" Margin="12" Click="OnSignOut"
                    Foreground="{StaticResource QrmeT2Brush}" Background="Transparent" />
        </NavigationView.PaneFooter>
        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Page>
