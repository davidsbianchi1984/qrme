<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QrmeStudio.Views.ConnectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource QrmeScrBotBrush}">

    <Pivot MaxWidth="680" Margin="20,12" Foreground="{StaticResource QrmeTxtBrush}">

        <!-- Social platform connections -->
        <PivotItem Header="Social">
            <ScrollViewer>
                <StackPanel Spacing="12" Padding="4">
                    <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                            BorderThickness="1" CornerRadius="16" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Social platforms" FontWeight="Bold" FontSize="16"
                                       Foreground="{StaticResource QrmeTxtBrush}" />
                            <TextBlock Text="Collect pulls the account's content in to grow the profile; publish runs the profile on the platform (moderated)."
                                       FontSize="12" TextWrapping="Wrap"
                                       Foreground="{StaticResource QrmeT2Brush}" />
                            <ComboBox x:Name="PlatformBox" Header="Platform" HorizontalAlignment="Stretch" />
                            <TextBox x:Name="HandleBox" Header="Handle (optional)" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Connect to collect" Click="OnConnectCollect"
                                        Background="{StaticResource QrmeBrandABrush}" Foreground="White" />
                                <Button Content="Connect to publish" Click="OnConnectPublish"
                                        Background="{StaticResource QrmeBrandABrush}" Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="SocialError" Foreground="{StaticResource QrmeRedBrush}" FontSize="13"
                               TextWrapping="Wrap" Visibility="Collapsed" />
                    <TextBlock x:Name="SocialStatus" Foreground="{StaticResource QrmeGreenBrush}" FontSize="12"
                               TextWrapping="Wrap" Visibility="Collapsed" />
                    <ItemsControl x:Name="SocialList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                                        BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,6">
                                    <StackPanel Spacing="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                       Foreground="{StaticResource QrmeTxtBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Handle}" FontSize="12"
                                                       Foreground="{StaticResource QrmeT2Brush}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Tally}" FontSize="12"
                                                   Foreground="{StaticResource QrmeT2Brush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    Visibility="{Binding ActiveVisibility}">
                                            <Button Content="Collect sample" Tag="{Binding Id}" Click="OnCollect"
                                                    Visibility="{Binding CollectVisibility}"
                                                    Background="{StaticResource QrmeBrandABrush}" Foreground="White" FontSize="12" />
                                            <Button Content="Publish update" Tag="{Binding Id}" Click="OnPublish"
                                                    Visibility="{Binding PublishVisibility}"
                                                    Background="{StaticResource QrmeBrandABrush}" Foreground="White" FontSize="12" />
                                            <Button Content="Disconnect" Tag="{Binding Id}" Click="OnRevoke"
                                                    Background="Transparent" FontSize="12"
                                                    Foreground="{StaticResource QrmeRedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </PivotItem>

        <!-- Connected-apps catalog -->
        <PivotItem Header="Apps">
            <ScrollViewer>
                <StackPanel Spacing="12" Padding="4">
                    <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                            BorderThickness="1" CornerRadius="16" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Connected apps" FontWeight="Bold" FontSize="16"
                                       Foreground="{StaticResource QrmeTxtBrush}" />
                            <TextBlock Text="Apple, Google, Microsoft, and Canva apps the profile's agents can collect from, act through, and produce with."
                                       FontSize="12" TextWrapping="Wrap"
                                       Foreground="{StaticResource QrmeT2Brush}" />
                            <ItemsControl x:Name="CatalogList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="{StaticResource QrmeTxtBrush}" />
                                                <TextBlock Text="{Binding Provider}" FontSize="11"
                                                           Foreground="{StaticResource QrmeT2Brush}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Connect" Tag="{Binding Key}"
                                                    Click="OnAppConnect" VerticalAlignment="Center"
                                                    Background="Transparent" FontSize="12"
                                                    Foreground="{StaticResource QrmeBrandABrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="AppsError" Foreground="{StaticResource QrmeRedBrush}" FontSize="13"
                               TextWrapping="Wrap" Visibility="Collapsed" />
                    <TextBlock x:Name="AppsStatus" Foreground="{StaticResource QrmeGreenBrush}" FontSize="12"
                               TextWrapping="Wrap" Visibility="Collapsed" />
                    <ItemsControl x:Name="AppConnList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                                        BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,6">
                                    <StackPanel Spacing="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                       Foreground="{StaticResource QrmeTxtBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Provider}" FontSize="12"
                                                       Foreground="{StaticResource QrmeT2Brush}" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    Visibility="{Binding ActiveVisibility}">
                                            <Button Content="Collect" Tag="{Binding Id}" Click="OnAppCollect"
                                                    Background="{StaticResource QrmeBrandABrush}" Foreground="White" FontSize="12" />
                                            <Button Content="{Binding InvokeLabel}" Tag="{Binding Id}" Click="OnAppInvoke"
                                                    Visibility="{Binding InvokeVisibility}"
                                                    Background="{StaticResource QrmeBrandABrush}" Foreground="White" FontSize="12" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </PivotItem>
    </Pivot>
</Page>
