<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QrmeStudio.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource QrmeScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="440" Spacing="20" Padding="24,40" HorizontalAlignment="Center">
            <Ellipse Width="84" Height="84" HorizontalAlignment="Center">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource QrmeBrandA}" Offset="0" />
                        <GradientStop Color="#FF3AA0FF" Offset="1" />
                    </LinearGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <TextBlock Text="Create your synthetic profile" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource QrmeTxtBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" />
            <TextBlock Text="A profile speaks in a voice you define — grounded in a persona, on your terms."
                       FontSize="13" Foreground="{StaticResource QrmeT2Brush}" HorizontalAlignment="Center"
                       TextAlignment="Center" TextWrapping="Wrap" />

            <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="12">
                    <TextBox x:Name="NameBox" Header="Display name" PlaceholderText="e.g. Ada" />
                    <TextBox x:Name="PersonaBox" Header="Persona" PlaceholderText="Voice, history, values."
                             AcceptsReturn="True" TextWrapping="Wrap" Height="80" />
                    <ComboBox x:Name="KindBox" Header="Kind" SelectedIndex="0" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="self" />
                        <ComboBoxItem Content="other_person" />
                        <ComboBoxItem Content="fictional" />
                    </ComboBox>
                    <ComboBox x:Name="LanguageBox" Header="Language" HorizontalAlignment="Stretch" />
                    <TextBox x:Name="BirthBox" Header="Birthdate (yyyy-MM-dd)" Text="1984-01-01" />
                </StackPanel>
            </Border>

            <TextBlock Text="By creating a profile you agree to the Terms of Service — profiles are AI-generated synthetic content, never professional advice; you assume the risks of AI interactions. Full terms: GET /terms · docs/terms.md"
                       Foreground="{StaticResource QrmeT3Brush}" FontSize="10" TextWrapping="Wrap" />

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource QrmeRed}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed" />

            <Button x:Name="StartButton" Content="Create profile" HorizontalAlignment="Stretch"
                    Height="46" Foreground="White" Click="OnStart">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{StaticResource QrmeBrandA}" Offset="0" />
                        <GradientStop Color="#FF3AA0FF" Offset="1" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <TextBlock Text="Start the backend:  QRME_CORS_ORIGINS=* uvicorn qrme.api:app"
                       FontFamily="Consolas" FontSize="11" Foreground="{StaticResource QrmeT2Brush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </ScrollViewer>
</Page>
