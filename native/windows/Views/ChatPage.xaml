<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QrmeStudio.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource QrmeScrBotBrush}">

    <Grid MaxWidth="640" Padding="28" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Chat" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource QrmeTxtBrush}" />
            <TextBlock x:Name="Subtitle" Foreground="{StaticResource QrmeT2Brush}"
                       FontSize="13" TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,12">
            <ItemsControl x:Name="MessagesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource QrmeCardBrush}"
                                BorderBrush="{StaticResource QrmeLineBrush}" BorderThickness="1"
                                CornerRadius="13" Padding="12,9" Margin="0,0,0,8"
                                HorizontalAlignment="{Binding Align}">
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="14"
                                       Foreground="{StaticResource QrmeTxtBrush}" MaxWidth="420" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock x:Name="ErrorText" Foreground="{StaticResource QrmeRed}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed" />
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DraftBox" Grid.Column="0" PlaceholderText="Say something…" />
                <Button x:Name="SendButton" Grid.Column="1" Content="Send" Height="36"
                        Foreground="White" Click="OnSend">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource QrmeBrandA}" Offset="0" />
                            <GradientStop Color="#FF3AA0FF" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
