<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QrmeStudio.Views.PostsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource QrmeScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <TextBlock Text="Posts" FontSize="22" FontWeight="Bold" Foreground="{StaticResource QrmeTxtBrush}" />
            <TextBlock Text="Everything your profile has posted."
                       Foreground="{StaticResource QrmeT2Brush}" FontSize="13" TextWrapping="Wrap" />

            <ProgressRing x:Name="Loading" IsActive="True" Foreground="{StaticResource QrmeBrandABrush}"
                          Width="24" Height="24" HorizontalAlignment="Left" />
            <TextBlock x:Name="Empty" Text="No posts yet — write one in Compose."
                       Foreground="{StaticResource QrmeT2Brush}" FontSize="13" Visibility="Collapsed"
                       TextWrapping="Wrap" />

            <ItemsControl x:Name="PostsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                                BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource QrmeT2Brush}"
                                           FontSize="12" FontWeight="Bold" />
                                <TextBlock Text="{Binding Content}" Foreground="{StaticResource QrmeTxtBrush}"
                                           FontSize="14" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
