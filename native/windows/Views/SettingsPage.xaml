<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QrmeStudio.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource QrmeScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="{StaticResource QrmeTxtBrush}" />

            <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Model" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource QrmeTxtBrush}" />
                    <TextBlock Text="Which LLM powers this profile. Unconfigured providers fall back to the offline stub."
                               Foreground="{StaticResource QrmeT2Brush}" FontSize="12" TextWrapping="Wrap" />
                    <ComboBox x:Name="ProviderBox" HorizontalAlignment="Stretch"
                              SelectionChanged="OnProviderPicked" />
                    <TextBlock x:Name="EffectiveText" Foreground="{StaticResource QrmeT2Brush}" FontSize="12" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Language" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource QrmeTxtBrush}" />
                    <TextBlock Text="The profile speaks this language everywhere it appears — chat, posts, rooms, robot speech."
                               Foreground="{StaticResource QrmeT2Brush}" FontSize="12" TextWrapping="Wrap" />
                    <ComboBox x:Name="LanguageBox" HorizontalAlignment="Stretch"
                              SelectionChanged="OnLanguagePicked" />
                    <ToggleSwitch x:Name="PreTranslateToggle" Header="Speak it natively (pre-translate)"
                                  OnContent="The persona speaks the language everywhere"
                                  OffContent="Original voice kept — translate below"
                                  IsOn="True" Toggled="OnModeToggled" />
                    <TextBox x:Name="TranslateBox" Header="Translate anything"
                             PlaceholderText="Paste or type text…" />
                    <Button Content="Translate" Click="OnTranslate"
                            Background="{StaticResource QrmeBrandABrush}" Foreground="White" FontSize="12" />
                    <TextBlock x:Name="TranslateOut" FontSize="13" TextWrapping="Wrap"
                               Foreground="{StaticResource QrmeTxtBrush}" Visibility="Collapsed" />
                    <TextBlock x:Name="TranslateEngine" FontSize="10" TextWrapping="Wrap"
                               Foreground="{StaticResource QrmeT2Brush}" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Objections" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource QrmeTxtBrush}" />
                    <TextBlock x:Name="NoObjections" Text="No objections — nobody has contested this profile."
                               Foreground="{StaticResource QrmeT2Brush}" FontSize="13" />
                    <ItemsControl x:Name="ObjectionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4" Margin="0,4">
                                    <TextBlock Text="{Binding Status}" FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource QrmeT2Brush}" />
                                    <TextBlock Text="{Binding Reason}" Foreground="{StaticResource QrmeTxtBrush}"
                                               FontSize="13" TextWrapping="Wrap" />
                                    <Button Content="Re-attest my rights basis" Tag="{Binding Id}"
                                            Click="OnAttest" Visibility="{Binding AttestVisibility}"
                                            Background="Transparent" Foreground="{StaticResource QrmeBrandABrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource QrmeRed}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</Page>
