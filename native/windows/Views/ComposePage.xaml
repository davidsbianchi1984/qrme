<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QrmeStudio.Views.ComposePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource QrmeScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <TextBlock Text="Compose" FontSize="22" FontWeight="Bold" Foreground="{StaticResource QrmeTxtBrush}" />
            <TextBlock Text="Give a topic — your profile writes a post in its own voice."
                       Foreground="{StaticResource QrmeT2Brush}" FontSize="13" TextWrapping="Wrap" />

            <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <TextBox x:Name="TopicBox" Header="Topic" PlaceholderText="What should it post about?"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="80" />
                    <Button x:Name="SendButton" Content="Compose post" HorizontalAlignment="Stretch"
                            Height="44" Foreground="White" Click="OnCompose">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource QrmeBrandA}" Offset="0" />
                                <GradientStop Color="#FF3AA0FF" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource QrmeRed}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed" />

            <Border x:Name="ResultCard" Background="{StaticResource QrmeCardBrush}"
                    BorderBrush="{StaticResource QrmeLineBrush}" BorderThickness="1" CornerRadius="16"
                    Padding="16" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="StatusText" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource QrmeTxtBrush}" />
                    <TextBlock x:Name="ContentText" Foreground="{StaticResource QrmeTxtBrush}"
                               FontSize="14" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
