<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QrmeStudio.Views.RobotsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource QrmeScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <TextBlock Text="Robots" FontSize="22" FontWeight="Bold" Foreground="{StaticResource QrmeTxtBrush}" />
            <TextBlock Text="Same persona · a physical body. Commands follow a per-body allowlist."
                       Foreground="{StaticResource QrmeT2Brush}" FontSize="13" TextWrapping="Wrap" />

            <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <ComboBox x:Name="ModelBox" Header="Bind a robot" HorizontalAlignment="Stretch" />
                    <Button x:Name="BindButton" Content="Bind" HorizontalAlignment="Stretch"
                            Height="42" Foreground="White" Click="OnBind">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource QrmeBrandA}" Offset="0" />
                                <GradientStop Color="#FF3AA0FF" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <TextBox x:Name="TopicBox" Header="Topic for &quot;say&quot;"
                             PlaceholderText="What should it speak about?" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource QrmeRed}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed" />

            <ItemsControl x:Name="RobotsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource QrmeCardBrush}" BorderBrush="{StaticResource QrmeLineBrush}"
                                BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                               Foreground="{StaticResource QrmeTxtBrush}" />
                                    <TextBlock Text="{Binding Status}" HorizontalAlignment="Right"
                                               Foreground="{StaticResource QrmeT2Brush}" FontSize="12" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Say" Tag="{Binding Id}" Click="OnSay"
                                            Visibility="{Binding SayVisibility}"
                                            Background="Transparent" Foreground="{StaticResource QrmeBrandABrush}" />
                                    <Button Content="Clean" Tag="{Binding Id}" Click="OnClean"
                                            Visibility="{Binding CleanVisibility}"
                                            Background="Transparent" Foreground="{StaticResource QrmeBrandABrush}" />
                                    <Button Content="Patrol" Tag="{Binding Id}" Click="OnPatrol"
                                            Background="Transparent" Foreground="{StaticResource QrmeBrandABrush}" />
                                    <Button Content="Dock" Tag="{Binding Id}" Click="OnDock"
                                            Background="Transparent" Foreground="{StaticResource QrmeT2Brush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border x:Name="ResultCard" Background="{StaticResource QrmeCardBrush}"
                    BorderBrush="{StaticResource QrmeLineBrush}" BorderThickness="1" CornerRadius="16"
                    Padding="16" Visibility="Collapsed">
                <StackPanel Spacing="6">
                    <TextBlock Text="Result" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource QrmeTxtBrush}" />
                    <TextBlock x:Name="ResultText" Foreground="{StaticResource QrmeTxtBrush}"
                               FontSize="14" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
