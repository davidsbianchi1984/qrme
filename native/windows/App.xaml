<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="QrmeStudio.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- QRME dark-OLED palette -->
            <Color x:Key="QrmeScrBot">#FF0A0F1C</Color>
            <Color x:Key="QrmeCard">#FF182238</Color>
            <Color x:Key="QrmeLine">#FF26314E</Color>
            <Color x:Key="QrmeTxt">#FFEEF1F7</Color>
            <Color x:Key="QrmeT2">#FF8A94AD</Color>
            <Color x:Key="QrmeBrandA">#FF7C5CFF</Color>
            <Color x:Key="QrmeGreen">#FF43E08A</Color>
            <Color x:Key="QrmeRed">#FFFF3B30</Color>
            <Color x:Key="QrmeT3">#FF626D88</Color>
            <Color x:Key="QrmeAmber">#FFF7B731</Color>
            <SolidColorBrush x:Key="QrmeScrBotBrush" Color="{StaticResource QrmeScrBot}" />
            <SolidColorBrush x:Key="QrmeCardBrush" Color="{StaticResource QrmeCard}" />
            <SolidColorBrush x:Key="QrmeLineBrush" Color="{StaticResource QrmeLine}" />
            <SolidColorBrush x:Key="QrmeTxtBrush" Color="{StaticResource QrmeTxt}" />
            <SolidColorBrush x:Key="QrmeT2Brush" Color="{StaticResource QrmeT2}" />
            <SolidColorBrush x:Key="QrmeBrandABrush" Color="{StaticResource QrmeBrandA}" />
            <SolidColorBrush x:Key="QrmeGreenBrush" Color="{StaticResource QrmeGreen}" />
            <SolidColorBrush x:Key="QrmeRedBrush" Color="{StaticResource QrmeRed}" />
            <SolidColorBrush x:Key="QrmeT3Brush" Color="{StaticResource QrmeT3}" />
            <SolidColorBrush x:Key="QrmeAmberBrush" Color="{StaticResource QrmeAmber}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
